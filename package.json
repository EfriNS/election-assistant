{
  "name": "election-assistant",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Efri Nattel-Shay",
  "repository": {
    "type": "git",
    "url": "https://github.com/EfriNS/election-assistant.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "export:questions": "tsx scripts/export-questions-review.ts",
    "export:grounding-review": "tsx scripts/render-grounding-review.ts",
    "score:auto": "tsx --env-file .env.local scripts/auto-score.ts",
    "score:apply": "tsx scripts/apply-scores.ts",
    "score:apply:write": "tsx scripts/apply-scores.ts --apply",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@google/genai": "^2.8.0",
    "@sparticuz/chromium": "^147.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "autoprefixer": "^10.5.0",
    "langfuse": "^3.38.20",
    "mixpanel-browser": "^2.80.0",
    "next": "^16.2.9",
    "puppeteer-core": "^24.43.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8",
    "puppeteer": "^24.43.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
